function(ce_generate_config)
    set(RT "${CMAKE_SOURCE_DIR}/Engine/Source/Runtime")
    set(CFG "")

    set(MODULES Core Project CoreUObject Asset AssetImport RenderCore RHI.OpenGL Renderer Engine Launch)
    foreach(MOD ${MODULES})
        file(COPY "${RT}/${MOD}/Public/"
            DESTINATION "${CE_OUTPUT_ROOT}/Include/${MOD}")
    endforeach()

    string(APPEND CFG "# Auto-generated by ClubEngine build — do not edit\n\n")

    string(APPEND CFG "function(ce_import NAME DLL_NAME INCLUDE_DIR)\n")
    string(APPEND CFG "    add_library(\${NAME} SHARED IMPORTED)\n")
    string(APPEND CFG "    set_target_properties(\${NAME} PROPERTIES\n")
    string(APPEND CFG "        IMPORTED_LOCATION \"\${CMAKE_CURRENT_LIST_DIR}/lib\${DLL_NAME}.dll\"\n")
    string(APPEND CFG "        IMPORTED_IMPLIB \"\${CMAKE_CURRENT_LIST_DIR}/lib\${DLL_NAME}.dll.a\"\n")
    string(APPEND CFG "        INTERFACE_INCLUDE_DIRECTORIES \"\${INCLUDE_DIR}\"\n")
    string(APPEND CFG "    )\n")
    string(APPEND CFG "endfunction()\n\n")

    string(APPEND CFG "ce_import(ClubEngine::Core        ClubEngine-Core        \"\${CMAKE_CURRENT_LIST_DIR}/Include/Core\")\n")
    string(APPEND CFG "ce_import(ClubEngine::Project     ClubEngine-Project     \"\${CMAKE_CURRENT_LIST_DIR}/Include/Project\")\n")
    string(APPEND CFG "ce_import(ClubEngine::CoreUObject ClubEngine-CoreUObject \"\${CMAKE_CURRENT_LIST_DIR}/Include/CoreUObject\")\n")
    string(APPEND CFG "ce_import(ClubEngine::Asset       ClubEngine-Asset       \"\${CMAKE_CURRENT_LIST_DIR}/Include/Asset\")\n")
    string(APPEND CFG "ce_import(ClubEngine::AssetImport ClubEngine-AssetImport \"\${CMAKE_CURRENT_LIST_DIR}/Include/AssetImport\")\n")
    string(APPEND CFG "ce_import(ClubEngine::RenderCore  ClubEngine-RenderCore  \"\${CMAKE_CURRENT_LIST_DIR}/Include/RenderCore\")\n")
    string(APPEND CFG "ce_import(ClubEngine::RHIOpenGL   ClubEngine-RHI-OpenGL  \"\${CMAKE_CURRENT_LIST_DIR}/Include/RHI.OpenGL\")\n")
    string(APPEND CFG "ce_import(ClubEngine::Renderer    ClubEngine-Renderer    \"\${CMAKE_CURRENT_LIST_DIR}/Include/Renderer\")\n")
    string(APPEND CFG "ce_import(ClubEngine::Engine      ClubEngine-Engine      \"\${CMAKE_CURRENT_LIST_DIR}/Include/Engine\")\n")
    string(APPEND CFG "ce_import(ClubEngine::Launch      ClubEngine-Launch      \"\${CMAKE_CURRENT_LIST_DIR}/Include/Launch\")\n\n")

    string(APPEND CFG "# Dependency chains\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::CoreUObject INTERFACE ClubEngine::Core)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::Asset       INTERFACE ClubEngine::CoreUObject ClubEngine::RenderCore)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::RenderCore  INTERFACE ClubEngine::Core)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::RHIOpenGL   INTERFACE ClubEngine::RenderCore)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::Renderer    INTERFACE ClubEngine::RenderCore ClubEngine::Asset)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::Engine      INTERFACE ClubEngine::Core ClubEngine::Asset)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::Launch      INTERFACE ClubEngine::Engine)\n")
    string(APPEND CFG "target_link_libraries(ClubEngine::Project     INTERFACE ClubEngine::Core)\n")

    file(WRITE "${CE_OUTPUT_ROOT}/ClubEngineConfig.cmake" "${CFG}")
    message(STATUS "[ClubEngine] Generated ClubEngineConfig.cmake in ${CE_OUTPUT_ROOT}")
endfunction()